# ── WhatsApp ─────────────────────────────────────────────────
WHATSAPP_PROVIDER=meta          # whapi | meta | twilio

META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=sercop-verify-prod

# ── Base de datos principal (PostgreSQL en producción) ────────
DATABASE_URL=postgresql+asyncpg://sercop_admin:CAMBIA_ESTO@localhost:5432/sercop_db

# ── Ollama + LLM ─────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b          # gemma4:26b en servidor con GPU
# Ventana de contexto: 4096 recomendado en CPU (~10-20s).
# Subir a 8192 solo si hay GPU disponible.
OLLAMA_NUM_CTX=4096
# Máximo de tokens a generar en la respuesta.
OLLAMA_MAX_TOKENS=512
# Timeout en segundos para la llamada a Ollama.
OLLAMA_TIMEOUT=120

# ── RAG ──────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100
EMBED_BATCH_SIZE=32
WIKI_FALLBACK=true

# ── Reranker ──────────────────────────────────────────────────
# RERANKER_ENABLED=false  → desactiva el cross-encoder, usa orden RRF directo
# Útil si no hay acceso a internet para descargar el modelo la primera vez.
RERANKER_ENABLED=true
# HF_HOME: dónde cachear los modelos HuggingFace en disco.
# Si no se define, se usa models/hf_cache/ dentro del proyecto.
# HF_HOME=/ruta/absoluta/al/cache

# ── App ──────────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=production
