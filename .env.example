# ── WhatsApp ─────────────────────────────────────────────────
WHATSAPP_PROVIDER=meta          # whapi | meta | twilio

META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=sercop-verify-prod

# ── Base de datos principal (PostgreSQL en producción) ────────
DATABASE_URL=postgresql+asyncpg://sercop_admin:CAMBIA_ESTO@localhost:5432/sercop_db

# ── Proveedor LLM ─────────────────────────────────────────────
# "ollama" = LLM local (sin internet, privado)
# "groq"   = Groq API (gratis hasta 14.400 req/día, ~1-2s respuesta)
LLM_PROVIDER=ollama

# ── Groq API (solo si LLM_PROVIDER=groq) ─────────────────────
# Obtener key gratis en: console.groq.com
GROQ_API_KEY=
# llama-3.1-8b-instant  → 500K tokens/día gratis, ~200 conv/día, muy rápido
# llama-3.3-70b-versatile → 100K tokens/día gratis, ~40 conv/día, mayor calidad
GROQ_MODEL=llama-3.1-8b-instant

# ── Ollama + LLM local (solo si LLM_PROVIDER=ollama) ─────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
# Ventana de contexto: el system prompt de SARA tiene ~3500 tokens.
# 8192 es el mínimo real. Subir a 16384 solo con GPU disponible.
OLLAMA_NUM_CTX=8192
# Máximo de tokens a generar en la respuesta.
OLLAMA_MAX_TOKENS=400
# Timeout en segundos para la llamada a Ollama.
OLLAMA_TIMEOUT=120

# ── RAG ──────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100
EMBED_BATCH_SIZE=32
WIKI_FALLBACK=true
# Chunks finales inyectados al prompt. 2 = más rápido, 4 = más contexto.
TOP_K_CHUNKS=2
# Mensajes de historial enviados al LLM. Bajar reduce tokens y latencia.
HISTORIAL_LIMITE=4

# ── Reranker ──────────────────────────────────────────────────
# RERANKER_ENABLED=false → desactiva el cross-encoder, usa orden RRF directo
RERANKER_ENABLED=false
# HF_HOME: dónde cachear los modelos HuggingFace en disco.
# HF_HOME=/ruta/absoluta/al/cache

# ── App ──────────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=production
