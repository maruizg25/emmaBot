# ── WhatsApp ─────────────────────────────────────────────────
WHATSAPP_PROVIDER=meta          # whapi | meta | twilio

META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=sercop-verify-prod

# ── Base de datos principal (PostgreSQL en producción) ────────
DATABASE_URL=postgresql+asyncpg://sercop_admin:CAMBIA_ESTO@192.168.9.230:5432/sercop_db

# ── Cascada de LLMs ───────────────────────────────────────────
# Orden de intento: groq → claude → gemini → local
LLM_FALLBACK_ORDER=groq,claude,gemini,local

# NIVEL 1: Groq API (gratis hasta 14.400 req/día, ~1-2s respuesta)
# Obtener key gratis en: console.groq.com
GROQ_API_KEY=
# Modelo para cascada (distinto al legacy LLM_PROVIDER=groq)
GROQ_MODEL_CASCADE=llama-3.3-70b-versatile
# Modelo legacy (si se usa LLM_PROVIDER=groq directo)
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# NIVEL 2: Anthropic / Claude Haiku 4.5
ANTHROPIC_API_KEY=

# NIVEL 3: Google Gemini 2.5 Flash-Lite
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite-preview-06-17

# NIVEL 4: Ollama local (fallback final — sin internet)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
# Ventana de contexto: el system prompt de Sercobot tiene ~3500 tokens.
# 8192 es el mínimo real. Subir a 16384 solo con GPU disponible.
OLLAMA_NUM_CTX=8192
# Máximo de tokens a generar en la respuesta.
OLLAMA_MAX_TOKENS=400

# ── RAG ──────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100
EMBED_BATCH_SIZE=32
WIKI_FALLBACK=true
# Chunks finales inyectados al prompt. 2 = más rápido, 4 = más contexto.
TOP_K_CHUNKS=2
# Mensajes de historial enviados al LLM. Bajar reduce tokens y latencia.
HISTORIAL_LIMITE=4

# ── Reranker ──────────────────────────────────────────────────
# RERANKER_ENABLED=false → desactiva el cross-encoder, usa orden RRF directo
RERANKER_ENABLED=false

# ── App ──────────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=production
ADMIN_TOKEN=
